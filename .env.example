# =============================================================================
# NATI — Environment template (canonical).
# Copy the backend section to `backend/.env` and the frontend section to
# `frontend/.env`. Never commit real .env files (see .gitignore).
# =============================================================================

# ---------------------------------------------------------------------------
# BACKEND  ->  copy to backend/.env
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# API
API_PREFIX=api
API_VERSION=1
CORS_ORIGIN=http://localhost:8080
WEB_URL=http://localhost:8080

# Database (dev = local Postgres). For Supabase later, swap this one line for
# the Supabase pooled connection string — no schema/code changes required.
DATABASE_URL=postgresql://nati:nati@localhost:5432/nati?schema=public

# Auth / JWT — generate strong values in real environments
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_TTL=7d

# Cookies
COOKIE_SECRET=change-me-cookie-secret
COOKIE_SECURE=false
COOKIE_DOMAIN=localhost

# Rate limiting (requests per window)
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# --- Provider placeholders (wired in later phases, kept behind abstractions) ---
# Images (Cloudinary -> future S3)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Payments (Razorpay -> future Stripe/PayPal/COD)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=NATI <no-reply@nati.example>

# ---------------------------------------------------------------------------
# FRONTEND  ->  copy to frontend/.env
# ---------------------------------------------------------------------------
VITE_API_URL=http://localhost:3000/api/v1
