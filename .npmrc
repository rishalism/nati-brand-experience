# Keep dependency resolution strict — no phantom (undeclared) dependencies.
shamefully-hoist=false
# NestJS + some tooling reads reflect-metadata / decorators from hoisted deps;
# hoist only the ecosystem packages that expect a flat layout.
public-hoist-pattern[]=*reflect-metadata*
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
auto-install-peers=true
strict-peer-dependencies=false
