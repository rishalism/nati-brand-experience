NODE_ENV=development
PORT=3000

API_PREFIX=api
API_VERSION=1
CORS_ORIGIN=http://localhost:8080
WEB_URL=http://localhost:8080

# Local Postgres. Swap for the Supabase pooled URL in staging/prod (no code changes).
DATABASE_URL=postgresql://nati:nati@localhost:5432/nati?schema=public

JWT_ACCESS_SECRET=dev-access-secret-change-me-0123456789
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-0123456789
JWT_REFRESH_TTL=7d

COOKIE_SECRET=dev-cookie-secret-change-me-0123456789
COOKIE_SECURE=false
COOKIE_DOMAIN=localhost

THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Providers (optional in Phase 1)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RESEND_API_KEY=
EMAIL_FROM=NATI <no-reply@nati.example>
